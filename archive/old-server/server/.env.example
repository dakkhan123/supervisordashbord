# ─── SmartOps Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in the values.
# The .env file must be inside the /server directory.

# Port the Express server listens on (default: 5000)
PORT=5000

# MongoDB connection string
# For local MongoDB:  mongodb://localhost:27017/smartops
# For MongoDB Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/smartops
MONGO_URI=mongodb://localhost:27017/smartops
